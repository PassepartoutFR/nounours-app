{
  "manifest_version": 3,
  "name": "Un web de gentil",
  "version": "0.5.0",
  "description": "Remplace les commentaires mechants par des mascottes trolls (7 langues, themes, intensite, niveaux) + classement opt-in sans compte (nounours.app). Le filtrage reste 100% local.",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://nounours.app/*", "http://127.0.0.1:8790/*", "http://localhost:8790/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Un web de gentil",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["uwg-core.js", "content.js", "mirror.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
