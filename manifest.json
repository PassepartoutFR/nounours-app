{
  "manifest_version": 3,
  "name": "Un web de gentil",
  "version": "0.7.3",
  "description": "Remplace les commentaires méchants par des mascottes câlines et taquines. 8 langues, 100 % local, gratuit à vie. 🧸",
  "permissions": ["storage", "alarms", "offscreen"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://storage.googleapis.com https://tfhub.dev https://www.kaggle.com https://kaggle.com"
  },
  "host_permissions": ["https://nounours.app/*", "http://127.0.0.1:8790/*", "http://localhost:8790/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Un web de gentil",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["uwg-core.js", "content.js", "mirror.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
